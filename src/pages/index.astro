---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import GlowOverlay from '../components/GlowOverlay.astro';
import HeroCard from '../components/HeroCard.astro';
import QuoteCard from '../components/QuoteCard.astro';
import Buttons from '../components/Buttons.astro';
import TagChip from '../components/TagChip.astro';
import MusicPlayer from '../components/MusicPlayer.astro';

const focalImage = "https://raw.githubusercontent.com/abqoryme/astro-cv/refs/heads/main/d9538cab-db0f-491a-8c37-e422cf4fa1c6_20260513_135617_0000.png";
const backgroundImage = "https://raw.githubusercontent.com/abqoryme/astro-cv/refs/heads/main/20260513_140801_0000.png";
const avatar = "https://i.pinimg.com/736x/36/22/4d/36224d3bde9798e32563708b8dfcbd72.jpg";
---

<Layout>
	<main class="relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden">
		<!-- Background Layers -->
		<ParticleBackground backgroundImage={backgroundImage} />
		<GlowOverlay />
		
		<!-- Navigation -->
		<Navbar />
		<Sidebar />

		<!-- Hero Section -->
		<section class="relative z-10 w-full max-w-[1800px] h-screen flex items-center justify-between px-6 lg:px-24">
			
			<!-- Left: Editorial Typography -->
			<div class="flex-1 z-10 animate-fade-in" style="animation-delay: 0.4s;">
				<div class="relative">
					<h2 class="text-[120px] lg:text-[200px] font-serif leading-none tracking-tighter opacity-10 absolute -top-20 -left-10 select-none">MIGI</h2>
					<h1 class="text-[80px] lg:text-[140px] font-serif leading-none tracking-tight text-glow">MIGI</h1>
					<p class="text-2xl lg:text-4xl font-light tracking-[0.3em] uppercase text-white/60 mt-2">RY-U ABQORY リュウ</p>
					<div class="w-20 h-[2px] bg-white/40 my-8"></div>
					<p class="text-sm lg:text-base tracking-[0.5em] uppercase text-white/40">Demon Hunter • Division 4</p>
				</div>
			</div>

			<!-- Center: Focal Character Image -->
			<div class="absolute inset-0 flex items-center justify-center pointer-events-none z-20">
				<div id="character-container" class="relative w-full max-w-4xl h-full flex items-center justify-center transition-transform duration-700 ease-out">
					<!-- Protection Overlay -->
					<div class="absolute inset-0 z-30 pointer-events-auto cursor-default select-none" id="image-protector"></div>
					
					<img 
						src={focalImage} 
						alt="Ahmad Abqory" 
						class="h-[90%] lg:h-full object-contain animate-breath drop-shadow-[0_0_50px_rgba(255,255,255,0.1)] select-none pointer-events-none unselectable"
						draggable="false"
						oncontextmenu="return false;"
					/>
					
					<!-- Floating Cards around character -->
					<div class="absolute top-[20%] right-[-10%] hidden xl:block animate-float pointer-events-auto z-40">
						<HeroCard 
							avatar={avatar}
							name="Ahmad Abqory"
							role="Special Div 4"
						/>
					</div>
					
					<div class="absolute bottom-[25%] left-[-15%] hidden xl:block animate-float pointer-events-auto z-40" style="animation-delay: -2s;">
						<QuoteCard 
							quote="If our job is done, it's better if we just disappear."
							author="Aki Hayakawa"
						/>
					</div>
				</div>
			</div>

			<!-- Right: Large Vertical Title -->
			<div class="flex-1 flex flex-col items-end z-10 animate-fade-in" style="animation-delay: 0.6s;">
				<div class="text-right flex flex-col gap-2">
					<span class="text-[60px] lg:text-[100px] font-black leading-none tracking-tighter text-transparent bg-clip-text bg-gradient-to-b from-white to-white/20 select-none">CHAIN</span>
					<span class="text-[60px] lg:text-[100px] font-black leading-none tracking-tighter text-transparent bg-clip-text bg-gradient-to-b from-white to-white/20 select-none">SAW</span>
					<span class="text-[60px] lg:text-[100px] font-black leading-none tracking-tighter text-transparent bg-clip-text bg-gradient-to-b from-white to-white/20 select-none">MAN</span>
				</div>
				
				<!-- Action Icon Overlay -->
				<div class="mt-12 flex gap-4">
					<div 
						class="w-12 h-12 glass rounded-full flex items-center justify-center cursor-pointer hover:bg-white/20 transition-all group"
						onclick="window.toggleMusicPlayer()"
					>
						<svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
					</div>
					<div 
						id="mute-btn"
						class="w-12 h-12 glass rounded-full flex items-center justify-center cursor-pointer hover:bg-white/20 transition-all group"
						onclick="window.toggleMute()"
					>
						<svg id="volume-icon" class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path id="volume-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
						</svg>
					</div>
				</div>
			</div>
		</section>

		<!-- Bottom Area -->
		<div class="absolute bottom-12 left-0 w-full px-6 lg:px-24 z-30 flex flex-col md:flex-row items-end justify-between gap-8 animate-fade-in" style="animation-delay: 0.8s;">
			<!-- Tags -->
			<div class="flex flex-wrap gap-3">
				<TagChip label="Miyamura" />
				<TagChip label="Ahmad_Abqory" />
				<TagChip label="Chainsawman" />
				<TagChip label="Aki" />
			</div>

			<!-- Buttons -->
			<div class="flex flex-wrap items-center gap-4">
				<Buttons label="ABOUT ME" variant="primary" href="/about" />
				<Buttons label="R&D" variant="outline" href="/r-and-d" />
				<Buttons label="GIRLFRIEND" variant="outline" />
				<Buttons label="NEXT PAGE" variant="ghost" />
			</div>
		</div>

		<!-- Mobile Overlay for Typography readability -->
		<div class="absolute inset-0 bg-black/40 lg:hidden z-0"></div>
		
		<!-- Music Player Popup -->
		<MusicPlayer />
	</main>
</Layout>

<script>
	// Character Parallax Effect
	const container = document.getElementById('character-container');
	window.addEventListener('mousemove', (e) => {
		const x = (e.clientX / window.innerWidth - 0.5) * 40;
		const y = (e.clientY / window.innerHeight - 0.5) * 40;
		if (container) {
			container.style.transform = `translate(${x}px, ${y}px)`;
		}
	});

	// Handle Mute Toggle UI
	const volumePath = document.getElementById('volume-path');
	const VOLUME_SVG_PATH = "M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z";
	const MUTE_SVG_PATH = "M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636";

	window.addEventListener('music-mute-toggle', (e) => {
		if (volumePath) {
			volumePath.setAttribute('d', (e as CustomEvent).detail.muted ? MUTE_SVG_PATH : VOLUME_SVG_PATH);
		}
	});

	// --- IMAGE PROTECTION LOGIC ---
	// 1. Disable Right Click globally
	document.addEventListener('contextmenu', (e) => {
		e.preventDefault();
		return false;
	}, false);

	// 2. Disable DevTools Shortcuts
	document.addEventListener('keydown', (e) => {
		// Disable F12, Ctrl+Shift+I, Ctrl+Shift+J, Ctrl+U
		if (
			e.key === 'F12' ||
			(e.ctrlKey && e.shiftKey && (e.key === 'I' || e.key === 'J' || e.key === 'C')) ||
			(e.ctrlKey && e.key === 'u') ||
			(e.ctrlKey && e.key === 's')
		) {
			e.preventDefault();
			return false;
		}
	});

	// 3. Additional Drag Protection for the overlay
	const protector = document.getElementById('image-protector');
	if (protector) {
		protector.addEventListener('dragstart', (e) => e.preventDefault());
		protector.addEventListener('drop', (e) => e.preventDefault());
	}
</script>

<style>
	/* Custom Typography Glow */
	.text-glow {
		text-shadow: 0 0 30px rgba(255, 255, 255, 0.4),
					 0 0 60px rgba(255, 255, 255, 0.2);
	}

	/* Image Protection Styles */
	.unselectable {
		-webkit-user-drag: none;
		-khtml-user-drag: none;
		-moz-user-drag: none;
		-o-user-drag: none;
		user-drag: none;
		user-select: none;
		-moz-user-select: none;
		-webkit-user-select: none;
		-ms-user-select: none;
	}

	@media (max-width: 1024px) {
		h1 {
			font-size: 60px;
		}
		.text-glow {
			text-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
		}
	}
</style>
