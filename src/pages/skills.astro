---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import GlowOverlay from '../components/GlowOverlay.astro';
import Buttons from '../components/Buttons.astro';

const backgroundImage = "https://raw.githubusercontent.com/abqoryme/astro-cv/refs/heads/main/20260513_140801_0000.png";

const skills = [
  {
    name: "Astro",
    level: 95,
    category: "CORE ENGINE",
    rank: "SSR-RANK",
    description: "Island architecture for maximum performance.",
    projects: [
      { name: "My Portfolio CV", link: "https://github.com/abqoryme/" }
    ],
    color: "from-orange-500 to-red-600"
  },
  {
    name: "Node.js",
    level: 85,
    category: "BACKEND CORE",
    rank: "A-RANK",
    description: "Scalable server-side execution environment.",
    projects: [
      { name: "Whatsapp Bot", link: "https://github.com/abqoryme/" }
    ],
    color: "from-green-500 to-emerald-700"
  },
  {
    name: "Git",
    level: 90,
    category: "TIME MANIPULATION",
    rank: "S-RANK",
    description: "Version control and collaborative timeline management.",
    projects: [
      { name: "Workflow Master", link: "https://github.com/abqoryme/workflow" }
    ],
    color: "from-orange-600 to-red-800"
  }
];
---

<Layout title="STATUS WINDOW | SKILLS">
	<main class="relative min-h-screen w-full flex flex-col items-center overflow-hidden bg-[#050505]">
		<ParticleBackground backgroundImage={backgroundImage} />
		<GlowOverlay />
		<Navbar />
		<Sidebar />

		<section class="relative z-10 w-full max-w-7xl px-6 lg:px-24 py-32">
			<!-- Solo Leveling Header -->
			<div class="mb-20 animate-fade-in">
				<div class="flex items-center gap-4 mb-2">
					<div class="h-[2px] w-12 bg-cyan-500 shadow-[0_0_10px_#06b6d4]"></div>
					<span class="text-cyan-500 font-bold tracking-[0.5em] uppercase text-xs shadow-text-cyan">STATUS WINDOW</span>
				</div>
				<h1 class="text-6xl lg:text-8xl font-serif leading-none text-glow tracking-tighter uppercase">Player<br/><span class="text-white/20">Capabilities</span></h1>
                
                <div class="mt-8 flex gap-8 items-center border-l-2 border-cyan-500/30 pl-6 py-2">
                    <div>
                        <p class="text-[10px] text-white/40 uppercase tracking-widest mb-1">Job</p>
                        <p class="text-sm font-bold text-white uppercase tracking-widest">Fullstack Architect</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-white/40 uppercase tracking-widest mb-1">Level</p>
                        <p class="text-sm font-bold text-cyan-400 uppercase tracking-widest">LV. 01</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-white/40 uppercase tracking-widest mb-1">Title</p>
                        <p class="text-sm font-bold text-yellow-500 uppercase tracking-widest">(Heir) Shadow Monarch</p>
                    </div>
                </div>
			</div>

			<!-- Interactive Skills Layout (Circular/Abstract) -->
			<div class="relative min-h-[600px] flex items-center justify-center">
                <!-- Center Core -->
                <div class="absolute w-64 h-64 rounded-full border border-cyan-500/20 flex items-center justify-center animate-pulse">
                    <div class="w-48 h-48 rounded-full border border-cyan-500/40 flex items-center justify-center">
                        <div class="w-32 h-32 rounded-full bg-cyan-500/10 backdrop-blur-xl border border-cyan-500/60 flex items-center justify-center shadow-[0_0_50px_rgba(6,182,212,0.2)]">
                            <span class="text-2xl font-black text-cyan-500 tracking-tighter">SKILLS</span>
                        </div>
                    </div>
                </div>

                <!-- Skill Nodes -->
                {skills.map((skill, index) => {
                    const angle = (index / skills.length) * (2 * Math.PI);
                    const radius = 280;
                    const x = Math.cos(angle) * radius;
                    const y = Math.sin(angle) * radius;
                    
                    return (
                        <div 
                            class="skill-node absolute group cursor-pointer"
                            style={`transform: translate(${x}px, ${y}px); --delay: ${index * 0.1}s`}
                        >
                            <!-- Connection Line to Center -->
                            <div class="absolute top-1/2 left-1/2 w-[280px] h-[1px] bg-gradient-to-r from-cyan-500/50 to-transparent origin-left -translate-y-1/2 group-hover:from-cyan-400 transition-all duration-500 pointer-events-none" style={`transform: rotate(${angle + Math.PI}rad)`}></div>

                            <!-- Skill Icon/Circle -->
                            <div class="relative z-10 w-20 h-20 lg:w-24 lg:h-24 rounded-2xl glass-card flex items-center justify-center border-white/10 group-hover:border-cyan-500/50 transition-all duration-500 group-hover:scale-110 group-hover:shadow-[0_0_30px_rgba(6,182,212,0.3)] overflow-hidden">
                                <div class={`absolute inset-0 bg-gradient-to-br ${skill.color} opacity-0 group-hover:opacity-20 transition-opacity duration-500`}></div>
                                <span class="text-xs lg:text-sm font-bold text-white/80 group-hover:text-white transition-colors uppercase tracking-widest text-center px-2">{skill.name}</span>
                                
                                <!-- Level Indicator -->
                                <div class="absolute bottom-0 left-0 h-1 bg-cyan-500 shadow-[0_0_10px_#06b6d4]" style={`width: ${skill.level}%`}></div>
                            </div>

                            <!-- Detail Tooltip (Solo Leveling Style) -->
                            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 lg:left-full lg:ml-8 lg:-translate-y-1/2 w-64 glass-card p-5 border-cyan-500/30 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 pointer-events-auto">
                                <div class="flex justify-between items-start mb-3">
                                    <span class="text-[10px] text-cyan-500 font-bold tracking-widest">{skill.rank}</span>
                                    <span class="text-[10px] text-white/40 tracking-widest">{skill.category}</span>
                                </div>
                                <h3 class="text-lg font-bold text-white mb-2 tracking-tight">{skill.name}</h3>
                                <p class="text-xs text-white/60 leading-relaxed mb-4">{skill.description}</p>
                                
                                <div class="space-y-2">
                                    <p class="text-[10px] text-cyan-500/70 font-bold uppercase tracking-widest">Deployed Projects</p>
                                    {skill.projects.map(proj => (
                                        <a href={proj.link} target="_blank" class="flex items-center justify-between group/link p-2 rounded-lg bg-white/5 hover:bg-white/10 transition-all border border-transparent hover:border-white/10">
                                            <span class="text-[10px] text-white/80 font-medium">{proj.name}</span>
                                            <svg class="w-3 h-3 text-white/40 group-hover/link:text-cyan-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                            </svg>
                                        </a>
                                    ))}
                                </div>
                                
                                <!-- Decorative corner accents -->
                                <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-cyan-500"></div>
                                <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-cyan-500"></div>
                            </div>
                        </div>
                    );
                })}
            </div>

			<!-- Back to Home Button -->
			<div class="mt-32 flex items-center justify-center animate-fade-in" style="animation-delay: 0.8s;">
				<Buttons label="BACK TO HOME" variant="outline" href="/" />
			</div>
		</section>
	</main>
</Layout>

<style>
	.text-glow {
		text-shadow: 0 0 30px rgba(6, 182, 212, 0.4), 0 0 60px rgba(255, 255, 255, 0.1);
	}

    .shadow-text-cyan {
        text-shadow: 0 0 8px rgba(6, 182, 212, 0.6);
    }

    .glass-card {
        background: rgba(12, 14, 20, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
    }

    .skill-node {
        animation: float-in 1s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        animation-delay: var(--delay);
        opacity: 0;
        z-index: 10;
        transition: z-index 0s;
    }

    .skill-node:hover {
        z-index: 100;
    }

    @keyframes float-in {
        from {
            opacity: 0;
            scale: 0.5;
        }
        to {
            opacity: 1;
            scale: 1;
        }
    }

    /* Radial line animation on hover */
    .skill-node:hover .absolute.top-1\/2.left-1\/2.w-\[280px\] {
        background: linear-gradient(to right, #06b6d4, transparent);
        box-shadow: 0 0 15px rgba(6, 182, 212, 0.5);
    }

    @media (max-width: 1024px) {
        .skill-node {
            position: relative !important;
            transform: none !important;
            margin-bottom: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }
        
        .relative.min-h-\[600px\] {
            display: grid;
            grid-template-cols: repeat(2, 1fr);
            gap: 1.5rem;
            min-height: auto;
            padding: 2rem 0;
        }

        .absolute.top-1\/2.left-1\/2.w-\[280px\],
        .absolute.w-64.h-64.rounded-full {
            display: none;
        }

        .skill-node .absolute.top-1\/2.left-1\/2.-translate-x-1\/2 {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            margin-top: 0;
            width: calc(100vw - 4rem);
            max-width: 180px;
            padding: 1rem;
            z-index: 200;
        }

        .skill-node .absolute.top-1\/2.left-1\/2.-translate-x-1\/2 h3 {
            font-size: 1rem;
            margin-bottom: 0.25rem;
        }

        .skill-node .absolute.top-1\/2.left-1\/2.-translate-x-1\/2 p {
            font-size: 0.7rem;
            margin-bottom: 0.75rem;
        }

        .skill-node .absolute.top-1\/2.left-1\/2.-translate-x-1\/2 .space-y-2 {
            gap: 0.25rem;
        }

        .skill-node .absolute.top-1\/2.left-1\/2.-translate-x-1\/2 .flex.justify-between {
            margin-bottom: 0.5rem;
        }

        .skill-node .absolute.top-1\/2.left-1\/2.-translate-x-1\/2 a {
            padding: 0.35rem;
        }

        /* Overlay when tooltip is open on mobile */
        .skill-node:hover::after {
            content: '';
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(4px);
            z-index: 150;
            pointer-events: none;
        }
    }

    @media (max-width: 640px) {
        .relative.min-h-\[600px\] {
            grid-template-cols: repeat(2, 1fr);
            gap: 1rem;
        }

        .skill-node .w-20.h-20 {
            width: 4.5rem;
            height: 4.5rem;
        }
    }
</style>
