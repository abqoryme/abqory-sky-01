---

<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] w-[95%] max-w-7xl animate-fade-in">
  <div class="glass flex items-center justify-between px-6 py-3 rounded-full shadow-2xl border-white/20">
    <!-- Left: Social Icons -->
    <div class="flex items-center gap-4">
      {socialIcons.map(icon => (
        <a href={`${icon.url}`} target="_blank" class="text-white/60 hover:text-white transition-all hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
            <path d={icon.path} />
          </svg>
        </a>
      ))}
    </div>

    <!-- Right: Actions & Profile -->
    <div class="flex items-center gap-5">
      <button 
        class="text-white/60 hover:text-white transition-all hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.8)] relative"
        onclick="window.toggleNotifModal()"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
        </svg>
        <span id="nav-notif-dot" class="absolute top-0 right-0 w-2 h-2 bg-white rounded-full shadow-[0_0_10px_white] hidden"></span>
      </button>
      
      <div class="h-8 w-[1px] bg-white/10"></div>
      
      <div class="flex items-center gap-3 group cursor-pointer">
        <div class="w-10 h-10 rounded-full overflow-hidden border border-white/20 group-hover:border-white/50 transition-all shine-effect">
          <img src="https://i.pinimg.com/736x/36/22/4d/36224d3bde9798e32563708b8dfcbd72.jpg" alt="Avatar" class="w-full h-full object-cover" />
        </div>
        <div class="hidden sm:block">
          <p class="text-xs font-semibold text-white/90">Ahmad Abqory</p>
          <p class="text-[10px] text-white/40">Demon Hunter</p>
        </div>
      </div>
    </div>
  </div>
</nav>
