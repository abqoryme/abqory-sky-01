---
interface Props {
  id?: string;
  quote: string;
  author: string;
}

const { id, quote, author } = Astro.props;
const quoteId = id || quote.toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').slice(0, 32);
---

<div
  class="glass-card p-6 max-w-sm animate-float shadow-[0_20px_50px_rgba(0,0,0,0.5)] border-white/10 group overflow-hidden"
>
  <div class="relative z-10">
    <div class="flex items-center gap-2 mb-4">
      <div class="w-1 h-1 bg-white rounded-full"></div>
      <div class="w-1 h-1 bg-white/50 rounded-full"></div>
      <div class="w-1 h-1 bg-white/20 rounded-full"></div>
    </div>

    <p class="text-white/80 text-sm italic leading-relaxed mb-6 font-serif">
      "{quote}"
    </p>

    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div
          class="w-8 h-8 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-[10px] font-bold"
        >
          AH
        </div>
        <div>
          <p class="text-[10px] font-bold tracking-widest uppercase">
            {author}
          </p>
          <p class="text-[8px] text-white/40 tracking-widest uppercase">
            Special Division 4
          </p>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <div class="flex items-center gap-1.5">
          <button
            type="button"
            class="like-button p-2 rounded-full hover:bg-white/10 transition-all duration-300 group/like"
            data-id={quoteId}
            aria-label="Like quote"
          >
            <svg
              class="w-3 h-3 transition-colors duration-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </button>
          <span class="like-count text-[10px] font-bold text-white/40 tabular-nums">0</span>
        </div>
        
        <button
          type="button"
          class="share-button p-2 rounded-full hover:bg-white/10 transition-colors"
          data-quote={quote}
          data-author={author}
          aria-label="Share quote"
        >
          <svg
            class="w-3 h-3"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 100-2.684 3 3 0 000 2.684zm0 9a3 3 0 100-2.684 3 3 0 000 2.684z"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Shine sweep effect -->
  <div
    class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out pointer-events-none"
  >
  </div>
</div>

<script>
  function shareQuote(button: HTMLButtonElement) {
    const quote = button.dataset.quote || "";
    const author = button.dataset.author || "";
    const text = `"${quote}" — ${author}`;

    if (navigator.share) {
      navigator
        .share({
          title: `Quote by ${author}`,
          text,
        })
        .catch(() => {
          navigator.clipboard.writeText(text);
        });
    } else {
      navigator.clipboard.writeText(text);
      alert("Teks berhasil disalin ke clipboard!");
    }
  }

  const shareButtons = document.querySelectorAll(".share-button");
  shareButtons.forEach((button) => {
    button.addEventListener("click", () =>
      shareQuote(button as HTMLButtonElement),
    );
  });

  // Like Functionality
  async function initLikes() {
    const likeButtons = document.querySelectorAll(".like-button");
    console.log(`[Likes] Initializing ${likeButtons.length} buttons via Proxy`);
    
    likeButtons.forEach(async (btn) => {
      const button = btn as HTMLButtonElement;
      if (button.dataset.initialized) return;
      button.dataset.initialized = "true";

      const quoteId = button.dataset.id;
      if (!quoteId) return;

      const countSpan = button.parentElement?.querySelector(".like-count") as HTMLSpanElement;
      const svg = button.querySelector("svg") as SVGSVGElement;
      
      const hasLiked = localStorage.getItem(`liked_${quoteId}`);
      if (hasLiked) {
        svg.setAttribute("fill", "currentColor");
        svg.classList.add("text-red-500");
        button.classList.add("bg-red-500/10");
      }

      async function updateCount(isInitial = false) {
        try {
          const response = await fetch(`/api/likes/${quoteId}`);
          const data = await response.json();
          
          if (response.ok && data && data.count !== undefined) {
            const justLiked = button.dataset.justLiked === "true";
            if (!justLiked || data.count > 0) {
              countSpan.textContent = data.count.toString();
              button.dataset.justLiked = "false";
            }
          } else if (response.status === 400 || response.status === 404) {
            if (countSpan.textContent === "0" || isInitial) {
              countSpan.textContent = "0";
            }
          }
        } catch (err) {
          console.error(`[Likes Proxy] Failed to fetch for ${quoteId}:`, err);
        }
      }

      await updateCount(true);
      const interval = setInterval(updateCount, 15000);
      document.addEventListener('astro:before-preparation', () => clearInterval(interval), { once: true });

      button.addEventListener("click", async () => {
        if (localStorage.getItem(`liked_${quoteId}`)) return;

        localStorage.setItem(`liked_${quoteId}`, "true");
        button.dataset.justLiked = "true";

        const currentCount = parseInt(countSpan.textContent || "0");
        countSpan.textContent = (currentCount + 1).toString();
        svg.setAttribute("fill", "currentColor");
        svg.classList.add("text-red-500", "scale-125");
        button.classList.add("bg-red-500/10");
        
        setTimeout(() => svg.classList.remove("scale-125"), 200);

        try {
          const res = await fetch(`/api/likes/${quoteId}`, { method: 'POST' });
          if (!res.ok) throw new Error(`Proxy returned ${res.status}`);
          
          const data = await res.json();
          if (data && data.count !== undefined) {
            countSpan.textContent = data.count.toString();
          }
        } catch (err) {
          console.error(`[Likes Proxy] Failed to increment for ${quoteId}:`, err);
        }
      });
    });
  }

  // Initialize on load and on each page navigation (Astro View Transitions)
  initLikes();
  document.addEventListener('astro:page-load', initLikes);
</script>
