---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import GlowOverlay from '../components/GlowOverlay.astro';
import Buttons from '../components/Buttons.astro';
import MusicPlayer from '../components/MusicPlayer.astro';

const backgroundImage = "https://raw.githubusercontent.com/abqoryme/astro-cv/refs/heads/main/20260513_140801_0000.png";
const characterImage = "https://i.pinimg.com/736x/36/22/4d/36224d3bde9798e32563708b8dfcbd72.jpg";
---

<Layout title="ABOUT ME | Ahmad Abqory Mudabighi">
	<main class="relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden">
		<ParticleBackground backgroundImage={backgroundImage} />
		<GlowOverlay />

		<!-- Mobile Overlay for Typography readability -->
		<div class="absolute inset-0 bg-black/40 lg:hidden z-0"></div>

		<Navbar />
		<Sidebar />

		<section class="relative z-10 w-full max-w-7xl px-6 lg:px-24 py-32 flex flex-col lg:flex-row items-center gap-16">
			<!-- Visual Side -->
			<div class="flex-1 relative animate-fade-in">
				<div class="glass-card p-2 rounded-[2rem] overflow-hidden rotate-[-2deg] hover:rotate-0 transition-transform duration-700 shadow-[0_50px_100px_rgba(0,0,0,0.5)]">
					<img 
						src={characterImage} 
						alt="Ahmad Abqory Profile" 
						class="w-full aspect-[4/5] object-cover rounded-[1.8rem] brightness-75 hover:brightness-100 transition-all duration-700"
					/>
				</div>
				<!-- Decorative Floating Element -->
				<div class="absolute -bottom-8 -right-8 glass p-6 rounded-2xl animate-float shadow-2xl border-white/20 z-20">
					<p class="text-[10px] tracking-[0.3em] uppercase text-white/40 mb-1">Status</p>
					<p class="text-xs font-bold tracking-widest uppercase">Public Safety Devil Hunter</p>
				</div>
			</div>

			<!-- Content Side -->
			<div class="flex-1 animate-fade-in" style="animation-delay: 0.2s;">
				<span class="text-xs font-bold tracking-[0.5em] uppercase text-white/40 mb-4 block">Personal Profile</span>
				<h1 class="text-6xl lg:text-8xl font-serif leading-none mb-8 text-glow">Ahmad<br/><span class="text-white/40">Abqory Mudabighi</span></h1>
				
				<div class="space-y-6 text-white/70 leading-relaxed font-light text-sm lg:text-base max-w-lg">
					<p>
						A high-ranking Public Safety Devil Hunter, working under Makima's special squad. Known for his stoic demeanor and unwavering resolve, Abqory carries the weight of a tragic past with a single-minded goal.
					</p>
					<p>
						His combat style is refined and deadly, utilizing contracts with the Fox Devil, the Curse Devil, and eventually the Future Devil. He lives a disciplined life, often acting as the responsible figure for those around him.
					</p>
				</div>

				<div class="grid grid-cols-2 gap-8 my-12 border-y border-white/10 py-8">
					<div>
						<p class="text-[10px] tracking-[0.3em] uppercase text-white/40 mb-2">Division</p>
						<p class="text-sm font-bold tracking-widest">Special Division 4</p>
					</div>
					<div>
						<p class="text-[10px] tracking-[0.3em] uppercase text-white/40 mb-2">Contracts</p>
						<p class="text-sm font-bold tracking-widest">Fox, Curse, Future</p>
					</div>
				</div>

				<div class="flex items-center gap-6">
					<Buttons label="BACK TO HOME" variant="outline" href="/" />
					<div class="flex gap-4">
						<button id="share-page-btn" class="w-10 h-10 glass rounded-full flex items-center justify-center cursor-pointer hover:bg-white/20 transition-all">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 100-2.684 3 3 0 000 2.684zm0 9a3 3 0 100-2.684 3 3 0 000 2.684z" />
							</svg>
						</button>
					</div>

					<script is:inline>
						function setupAboutPage() {
							const shareBtn = document.getElementById('share-page-btn');
							if (shareBtn) {
								shareBtn.onclick = () => {
									if (navigator.share) {
										navigator.share({
											title: document.title,
											url: window.location.href
										});
									} else {
										navigator.clipboard.writeText(window.location.href);
										alert('Link copied to clipboard!');
									}
								};
							}
						}

						document.addEventListener('astro:page-load', setupAboutPage);
					</script>
				</div>
			</div>
		</section>
		
		<!-- Floating Music Toggle Button -->
		<div 
			class="fixed bottom-6 right-6 z-[100] w-14 h-14 glass rounded-full flex items-center justify-center cursor-pointer hover:bg-white/20 transition-all group animate-float shadow-2xl border border-white/20"
			onclick="window.toggleMusicPlayer()"
			title="Toggle Music Player"
		>
			<div class="absolute inset-0 rounded-full bg-white/5 animate-ping group-hover:animate-none"></div>
			<svg class="w-7 h-7 text-white/80 group-hover:scale-110 transition-transform relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
			</svg>
		</div>

		<!-- Music Player Popup -->
		<MusicPlayer />
	</main>
</Layout>

<style>
	.text-glow {
		text-shadow: 0 0 30px rgba(255, 255, 255, 0.3);
	}
</style>
