---
const menuItems = [
  { label: 'Profile', href: '/about', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
  { label: 'Documents', href: '/documents', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
  { label: 'Skills', href: '/skills', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { label: 'Collaborators', href: '/collaborators', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
];
---

<aside class="fixed left-6 top-1/2 -translate-y-1/2 z-[100] hidden lg:block animate-fade-in" style="animation-delay: 0.2s;">
  <div class="glass flex flex-col items-center py-8 px-4 rounded-3xl gap-8 border-white/20">
    {menuItems.map(item => (
      <a href={item.href} class="group relative flex flex-col items-center gap-2">
        <div class="p-3 rounded-2xl transition-all duration-300 group-hover:bg-white/10 group-hover:shadow-[0_0_20px_rgba(255,255,255,0.1)]">
          <svg class="w-6 h-6 text-white/50 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
          </svg>
        </div>
        <span class="absolute left-full ml-4 px-3 py-1 bg-white/10 backdrop-blur-md rounded-lg text-[10px] font-medium tracking-widest uppercase opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all pointer-events-none border border-white/10">
          {item.label}
        </span>
      </a>
    ))}
  </div>
</aside>
