---
interface Props {
  avatar: string;
  name: string;
  role: string;
}

const { avatar, name, role } = Astro.props;
---

<div class="glass-card p-4 flex items-center gap-4 border-white/10 group animate-float" style="animation-delay: -1s;">
  <div class="relative">
    <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white/20 group-hover:border-white/50 transition-all">
      <img src={avatar} alt={name} class="w-full h-full object-cover" />
    </div>
    <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-white rounded-full flex items-center justify-center border-2 border-black">
      <svg class="w-2 h-2 text-black" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293l-4 4a1 1 0 01-1.414 0l-2-2a1 1 0 111.414-1.414L9 10.586l3.293-3.293a1 1 0 111.414 1.414z" />
      </svg>
    </div>
  </div>
  
  <div class="flex-1">
    <h4 class="text-xs font-bold tracking-widest uppercase">RY-U ABQORY リュウ</h4>
    <p class="text-[10px] text-white/40 uppercase tracking-widest">{role}</p>
  </div>
  
  <button onclick="this.innerHTML='LOADING...'; setTimeout(() => window.location.href='https://whatsapp.com/channel/0029Vb7XsPXC1Fu5RneF1M0M', 600)" class="px-4 py-1.5 bg-white text-black text-[10px] font-bold rounded-full hover:bg-white/80 transition-all hover:scale-105 active:scale-95 shadow-[0_0_15px_rgba(255,255,255,0.3)]">
    FOLLOW
  </button>
</div>
