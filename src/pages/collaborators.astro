---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import GlowOverlay from '../components/GlowOverlay.astro';
import Buttons from '../components/Buttons.astro';
import { getCollection } from 'astro:content';

const backgroundImage = "https://raw.githubusercontent.com/abqoryme/astro-cv/refs/heads/main/20260513_140801_0000.png";
const collabs = await getCollection('collaborations');
---

<Layout title="COLLABORATORS | Ahmad Abqory">
	<main class="relative min-h-screen w-full flex flex-col items-center overflow-hidden bg-[#050505]">
		<ParticleBackground backgroundImage={backgroundImage} />
		<GlowOverlay />
		<Navbar />
		<Sidebar />

		<section class="relative z-10 w-full max-w-7xl px-6 lg:px-24 py-32">
			<div class="mb-20 animate-fade-in text-center lg:text-left">
				<span class="text-xs font-bold tracking-[0.5em] uppercase text-cyan-500 mb-4 block">Collaboration Archive</span>
				<h1 class="text-6xl lg:text-8xl font-serif leading-none text-glow uppercase">Missions<br/><span class="text-white/20">&amp; Allies</span></h1>
			</div>

			<div class="space-y-12 animate-fade-in" style="animation-delay: 0.4s;">
				{collabs.map((collab) => (
					<div class="glass-card overflow-hidden border-white/10 hover:border-cyan-500/20 transition-all duration-700">
						<div class="flex flex-col lg:flex-row">
							<div class="lg:w-1/3 p-8 border-b lg:border-b-0 lg:border-r border-white/10 bg-white/[0.02]">
								<div class="flex items-center gap-4 mb-8">
									<div class="w-16 h-16 rounded-2xl overflow-hidden border-2 border-cyan-500/30 shadow-[0_0_20px_rgba(6,182,212,0.2)]">
										<img src={collab.data.clientAvatar} alt={collab.data.clientName} class="w-full h-full object-cover" />
									</div>
									<div>
										<h3 class="font-bold text-white tracking-tight">{collab.data.clientName}</h3>
										<p class="text-[10px] text-white/40 uppercase tracking-widest">{collab.data.clientRole}</p>
                                        {collab.data.linkedinUrl && (
                                            <a href={collab.data.linkedinUrl} target="_blank" class="inline-flex items-center gap-1 mt-2 text-[8px] font-bold text-cyan-500/60 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]">
                                                <svg class="w-2 h-2" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                                                LinkedIn Verified
                                            </a>
                                        )}
									</div>
								</div>
								
								<div class="relative">
									<p class="text-sm text-white/70 italic leading-relaxed relative z-10 pl-4 border-l border-cyan-500/20">
										"{collab.data.testimonial?.text}"
									</p>
                                    {collab.data.testimonial?.audioUrl && (
                                        <div class="mt-4 audio-container max-w-[240px]">
                                            <button 
                                                data-audio-url={collab.data.testimonial.audioUrl}
                                                class="audio-play-btn flex items-center gap-2 text-[10px] font-bold text-cyan-500 hover:text-cyan-400 transition-colors uppercase tracking-widest"
                                            >
                                                <div class="w-6 h-6 rounded-full bg-cyan-500/20 flex items-center justify-center text-cyan-500 btn-icon">
                                                    <svg class="w-3 h-3 play-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                                    <svg class="w-3 h-3 pause-icon hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                                                </div>
                                                <span class="btn-text">Play Audio Feedback</span>
                                            </button>
                                            
                                            <div class="mt-2 flex items-center gap-3 opacity-0 transition-opacity duration-300 progress-container">
                                                <div class="h-[2px] flex-1 bg-white/5 rounded-full overflow-hidden">
                                                    <div class="h-full bg-cyan-500 shadow-[0_0_8px_rgba(6,182,212,0.8)] progress-bar" style="width: 0%;"></div>
                                                </div>
                                                <span class="text-[9px] font-mono text-white/40 tracking-wider whitespace-nowrap time-display">
                                                    0:00 / 0:00
                                                </span>
                                            </div>
                                        </div>
                                    )}
								</div>
							</div>

							<div class="lg:w-2/3 p-8">
								<div class="flex flex-col md:flex-row gap-12">
									<div class="flex-1">
										<h4 class="text-[10px] font-bold text-white/40 uppercase tracking-[0.3em] mb-6">Mission Contribution</h4>
										<div class="space-y-4">
											{collab.data.contributionDiagram.map(item => (
												<div class="space-y-1">
													<div class="flex justify-between text-[10px] uppercase tracking-widest font-bold">
														<span class="text-white/60">{item.role}</span>
														<span class="text-cyan-500">{item.percentage}%</span>
													</div>
													<div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
														<div class="h-full bg-gradient-to-r from-cyan-600 to-cyan-400 shadow-[0_0_10px_rgba(6,182,212,0.4)]" style={`width: ${item.percentage}%`}></div>
													</div>
												</div>
											))}
										</div>
									</div>

									<div class="flex-1">
										<h4 class="text-[10px] font-bold text-white/40 uppercase tracking-[0.3em] mb-6">Execution Timeline</h4>
										<div class="space-y-4 relative before:absolute before:left-[7px] before:top-2 before:bottom-2 before:w-[1px] before:bg-white/10">
											{collab.data.workflow.map(step => (
												<div class="flex gap-4 relative">
													<div class={`w-3.5 h-3.5 rounded-full border-2 border-[#050505] z-10 mt-1 ${step.status === 'done' ? 'bg-cyan-500 shadow-[0_0_10px_rgba(6,182,212,0.6)]' : 'bg-white/20'}`}></div>
													<div>
														<p class={`text-[10px] font-bold uppercase tracking-widest ${step.status === 'done' ? 'text-white' : 'text-white/40'}`}>{step.phase}</p>
														<p class="text-[9px] text-white/40 leading-tight">{step.description}</p>
													</div>
												</div>
											))}
										</div>
									</div>
								</div>

								<div class="mt-12 pt-8 border-t border-white/5">
									<h4 class="text-[10px] font-bold text-white/40 uppercase tracking-[0.3em] mb-4">Collaboration Ecosystem</h4>
									<div class="flex flex-wrap gap-2">
										{collab.data.tools.map(tool => (
											<span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[9px] font-bold text-white/60 uppercase tracking-widest">
												{tool}
											</span>
										))}
									</div>
								</div>
							</div>
						</div>
					</div>
				))}
			</div>

			<div class="mt-32 flex items-center justify-center animate-fade-in" style="animation-delay: 0.8s;">
				<Buttons label="BACK TO HOME" variant="outline" href="/" />
			</div>
		</section>
	</main>
</Layout>

<script>
    interface CustomAudioButton extends HTMLButtonElement {
        clickReset?: () => void;
    }

    document.addEventListener('astro:page-load', initAudioPlayers);
    initAudioPlayers();

    function initAudioPlayers(): void {
        const containers = document.querySelectorAll('.audio-container');
        let currentActiveAudio: HTMLAudioElement | null = null;
        let currentActiveButton: CustomAudioButton | null = null;

        function formatTime(seconds: number): string {
            if (isNaN(seconds)) return "0:00";
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs < 10 ? '0' : ''}${secs}`;
        }

        containers.forEach(container => {
            const button = container.querySelector('.audio-play-btn') as CustomAudioButton;
            const playIcon = container.querySelector('.play-icon') as SVGElement;
            const pauseIcon = container.querySelector('.pause-icon') as SVGElement;
            const btnText = container.querySelector('.btn-text') as HTMLSpanElement;
            const progressContainer = container.querySelector('.progress-container') as HTMLDivElement;
            const progressBar = container.querySelector('.progress-bar') as HTMLDivElement;
            const timeDisplay = container.querySelector('.time-display') as HTMLSpanElement;
            const audioUrl = button.getAttribute('data-audio-url');
            
            if (!audioUrl) return;
            let audio: HTMLAudioElement | null = null;

            button.addEventListener('click', () => {
                if (!audio) {
                    audio = new Audio(audioUrl);
                    
                    audio.addEventListener('loadedmetadata', () => {
                        if (audio) timeDisplay.textContent = `0:00 / ${formatTime(audio.duration)}`;
                    });
                    
                    audio.addEventListener('timeupdate', () => {
                        if (audio) {
                            const progress = (audio.currentTime / audio.duration) * 100;
                            progressBar.style.width = `${progress}%`;
                            timeDisplay.textContent = `${formatTime(audio.currentTime)} / ${formatTime(audio.duration)}`;
                        }
                    });

                    audio.addEventListener('ended', () => {
                        resetUI();
                    });
                }

                function resetUI(): void {
                    playIcon.classList.remove('hidden');
                    pauseIcon.classList.add('hidden');
                    btnText.textContent = "Play Audio Feedback";
                    progressContainer.classList.add('opacity-0');
                    progressBar.style.width = '0%';
                    if (audio) timeDisplay.textContent = `0:00 / ${formatTime(audio.duration)}`;
                }

                if (currentActiveAudio && currentActiveAudio !== audio) {
                    currentActiveAudio.pause();
                    if (currentActiveButton && currentActiveButton.clickReset) currentActiveButton.clickReset();
                }

                button.clickReset = resetUI;

                if (audio.paused) {
                    audio.play().then(() => {
                        playIcon.classList.add('hidden');
                        pauseIcon.classList.remove('hidden');
                        btnText.textContent = "Pause Audio";
                        progressContainer.classList.remove('opacity-0');
                        currentActiveAudio = audio;
                        currentActiveButton = button;
                    }).catch(err => console.error(err));
                } else {
                    audio.pause();
                    playIcon.classList.remove('hidden');
                    pauseIcon.classList.add('hidden');
                    btnText.textContent = "Resume Audio";
                }
            });
        });
    }
</script>

<style>
	.text-glow {
		text-shadow: 0 0 30px rgba(6, 182, 212, 0.4), 0 0 60px rgba(255, 255, 255, 0.1);
	}

	.glass-card {
		background: rgba(12, 14, 20, 0.6);
		backdrop-filter: blur(20px);
		border-radius: 2rem;
	}
</style>
